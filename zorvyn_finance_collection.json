		{
			"name": "Transactions",
			"item": [
				{
					"name": "Create",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"amount\": 1200.00,\n    \"type\": \"INCOME\",\n    \"category\": \"Salary\",\n    \"date\": \"2026-04-01\",\n    \"notes\": \"Initial paycheck\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/transactions",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"transactions"
							]
						},
						"description": "Add a new financial transaction. Access: ADMIN Only."
					},
					"response": []
				},
				{
					"name": "Get All",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/transactions",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"transactions"
							]
						},
						"description": "Fetch all transactions. Access: All logged-in users."
					},
					"response": []
				},
				{
					"name": "Filter (type/category/date/user)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/transactions?type=EXPENSE&category=Food&startDate=2026-04-01&endDate=2026-04-30&userId=1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"transactions"
							],
							"query": [
								{
									"key": "type",
									"value": "EXPENSE"
								},
								{
									"key": "category",
									"value": "Food"
								},
								{
									"key": "startDate",
									"value": "2026-04-01"
								},
								{
									"key": "endDate",
									"value": "2026-04-30"
								},
								{
									"key": "userId",
									"value": "1",
									"description": "Admin only filter"
								}
							]
						},
						"description": "Fetch filtered transactions. Admin can filter by userId to see other users' data. Access: All logged-in users (filtering limited by role)."
					},
					"response": []
				},
				{
					"name": "Get By ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/transactions/1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"transactions",
								"1"
							]
						},
						"description": "Fetch a single transaction's full details. Access: All logged-in users."
					},
					"response": []
				},
				{
					"name": "Delete",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/transactions/1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"transactions",
								"1"
							]
						},
						"description": "Soft delete a transaction. Access: ADMIN only."
					},
					"response": []
				},
				{
					"name": "Summary",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/transactions/summary?startDate=2026-04-01&endDate=2026-04-30",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"transactions",
								"summary"
							],
							"query": [
								{
									"key": "startDate",
									"value": "2026-04-01"
								},
								{
									"key": "endDate",
									"value": "2026-04-30"
								}
							]
						},
						"description": "Get aggregated totals (income, expense, balance, category totals) with optional date filtering. Access: All logged-in users."
					},
					"response": []
				}
			]
